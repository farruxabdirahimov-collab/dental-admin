# DentAdmin — Environment Variables
# Bu faylni .env deb nusxalang va o'z qiymatlaringizni kiriting

# Railway PostgreSQL - avtomatik taqdim etiladi
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT - 32+ belgili murakkab so'z tanlang
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT muddati (30d = 30 kun)
JWT_EXPIRES=30d

# Server port (Railway avtomatik $PORT beradi)
PORT=3000

# Production yoki development
NODE_ENV=production
